function renderCompliance() {
  initReportsCharts(); // reuse for comp chart
  const total=DB.crew.length;
  const expired=DB.crew.filter(c=>daysLeft(c.cocExp)<0).length;
  const soon=DB.crew.filter(c=>{const d=daysLeft(c.cocExp);return d>=0&&d<60;}).length;
  const valid=total-expired-soon;
  const pct=total?Math.round(valid/total*100):0;
  ['comp-pct','comp-valid','comp-soon','comp-exp'].forEach((id,i)=>{const el=document.getElementById(id);if(el)el.textContent=[pct+'%',valid,soon,expired][i];});
  const ranks=['Nakhoda (Master)','Mualim I (Chief Officer)','Mualim II','Mualim III','KKM (Chief Engineer)','Masinis I','Masinis II','Bosun','AB Deck'];
  const tbody=document.getElementById('comp-tbody');
  if(!tbody) return;
  const stcwRegs={'Nakhoda':'STCW II/2','Mualim I':'STCW II/2','Mualim II':'STCW II/1','Mualim III':'STCW II/1','KKM':'STCW III/2','Masinis I':'STCW III/1','Masinis II':'STCW III/1','Bosun':'STCW II/5','AB Deck':'STCW II/5'};
  tbody.innerHTML=ranks.map(rk=>{
    const rKey=rk.split('(')[0].trim();
    const crew=DB.crew.filter(c=>c.rank.startsWith(rKey));
    const allOk=crew.length&&crew.every(c=>daysLeft(c.cocExp)>30);
    const medOk=crew.length&&crew.every(c=>daysLeft(c.medExp)>0);
    const gmdssNeeded=['Nakhoda','Mualim I','Mualim II','Mualim III'].some(r=>rk.startsWith(r));
    const ecdisNeeded=['Nakhoda','Mualim I'].some(r=>rk.startsWith(r));
    const ok=`<span class="badge badge-success">✓</span>`;
    const na=`<span class="badge badge-muted">N/A</span>`;
    const warn=`<span class="badge badge-warning">⚠</span>`;
    const pctVal=crew.length?Math.round(crew.filter(c=>daysLeft(c.cocExp)>30).length/crew.length*100):100;
    return `<tr>
      <td style="font-size:12px;font-weight:600;">${rKey}</td>
      <td class="mono" style="font-size:10px;">${stcwRegs[rKey]||'STCW'}</td>
      <td>${crew.length?allOk?ok:warn:na}</td>
      <td>${ok}</td>
      <td>${gmdssNeeded?ok:na}</td>
      <td>${ecdisNeeded?ok:na}</td>
      <td>${crew.length?medOk?ok:warn:na}</td>
      <td><span class="badge badge-${pctVal>=90?'success':pctVal>=70?'warning':'danger'}">${pctVal}%</span></td>
    </tr>`;
  }).join('');
}

