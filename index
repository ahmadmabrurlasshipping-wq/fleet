const FMT_IDR = v => 'Rp ' + Math.round(v).toLocaleString('id-ID');

function renderPayrollPage() {
  // Populate vessel filter
  const vf = document.getElementById('payroll-vessel-filter');
  if(vf) { const cur=vf.value; vf.innerHTML='<option value="">Semua Kapal</option>'+DB.vessels.map(v=>`<option value="${v.id}">${v.name}</option>`).join(''); vf.value=cur; }
