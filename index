        <div>LOA<span>${v.loa}m</span></div>
        <div>Kru<span style="color:${pct<100?'var(--warning)':'var(--success)'}">${v.crew||13}/13</span></div>
      </div>
      <div class="prog"><div class="prog-fill ${v.status==='drydock'?'pf-orange':'pf-green'}" style="width:${pct}%"></div></div>
      <div class="vloc"><i class="fa fa-map-marker-alt" style="color:var(--orange)"></i>${v.location||'—'}</div>
    </div>`;
