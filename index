// ── Crew Documents ─────────────────────────────────────────────
function renderCrewDocs() {
  if(!DB.crewDocs) DB.crewDocs=[];
  // Populate vessel filter dropdown
  const vf = document.getElementById('cdoc-vessel-filter');
  if(vf){ const cur=vf.value; vf.innerHTML='<option value="">Semua Kapal</option>'+DB.vessels.map(v=>`<option value="${v.id}">${v.name}</option>`).join(''); vf.value=cur; }

  const vesFilter  = (document.getElementById('cdoc-vessel-filter')||{}).value||'';
  const rankFilter = (document.getElementById('cdoc-rank-filter')||{}).value||'';
  const typeFilter = (document.getElementById('cdoc-type-filter')||{}).value||'';
  const search     = ((document.getElementById('cdoc-search')||{}).value||'').toLowerCase();

  let rows = DB.crewDocs.filter(d=>{
    const c = DB.crew.find(x=>x.id===d.crewId)||{};
    if(vesFilter && c.vessel!==vesFilter) return false;
    if(rankFilter && c.rank!==rankFilter) return false;
    if(typeFilter && d.type!==typeFilter) return false;
    if(search && !(c.name||'').toLowerCase().includes(search)) return false;
    return true;
  });

  // KPI
  const total   = rows.length;
  const expired = rows.filter(d=>daysLeft(d.expiry)<0).length;
  const soon    = rows.filter(d=>{ const x=daysLeft(d.expiry); return x>=0&&x<60; }).length;
  const valid   = rows.filter(d=>daysLeft(d.expiry)>=60).length;
  ['cdoc-kpi-total','cdoc-kpi-valid','cdoc-kpi-soon','cdoc-kpi-exp'].forEach((id,i)=>{
    const el=document.getElementById(id); if(el) el.textContent=[total,valid,soon,expired][i];
  });

  // Urgent alerts
  const urgEl = document.getElementById('cdoc-urgent-alerts');
  if(urgEl){
    const urg = DB.crewDocs.filter(d=>{ const x=daysLeft(d.expiry); return x<30&&x>=0; });
    urgEl.innerHTML = urg.map(d=>{
      const c=DB.crew.find(x=>x.id===d.crewId)||{name:'?'};
      return `<div class="alert alert-danger mb8"><i class="fa fa-exclamation-triangle"></i><div><b>URGENT:</b> Sertifikat <b>${d.type}</b> milik <b>${c.name}</b> kadaluarsa dalam <b>${daysLeft(d.expiry)} hari</b> (${fmtDate(d.expiry)})</div></div>`;
    }).join('');
  }

  // Table
  const tbody = document.getElementById('cdoc-tbody');
  if(!tbody) return;
  if(!rows.length){ tbody.innerHTML=`<tr><td colspan="11" style="text-align:center;padding:16px;color:var(--text-400);">Tidak ada dokumen kru</td></tr>`; return; }
  tbody.innerHTML = rows.map(d=>{
    const c = DB.crew.find(x=>x.id===d.crewId)||{name:'—',rank:'—'};
    const v = DB.vessels.find(x=>x.id===c.vessel)||{name:'—'};
    const days = daysLeft(d.expiry);
    const isPerm = d.expiry==='9999-12-31';
    const statusBadge = d.status==='valid'
      ? `<span class="badge badge-success">Valid</span>`
      : d.status==='expired'
      ? `<span class="badge badge-danger">Kadaluarsa</span>`
      : d.status==='proses'
      ? `<span class="badge badge-warning">Proses</span>`
      : `<span class="badge badge-info">Pending</span>`;
    return `<tr>
      <td><div style="font-weight:600;font-size:12px;">${c.name}</div></td>
      <td><span class="badge badge-info" style="font-size:9px;">${c.rank}</span></td>
      <td style="font-size:11px;color:var(--neon)">${v.name}</td>
      <td><span class="badge badge-warning" style="font-size:9px;">${d.type}</span></td>
      <td class="mono" style="font-size:10px;">${d.docNumber||'—'}</td>
      <td style="font-size:10px;color:var(--text-400);">${d.issuer||'—'}</td>
      <td class="mono" style="font-size:10px;">${fmtDate(d.issue)}</td>
      <td class="mono" style="font-size:10px;">${isPerm?'PERMANEN':fmtDate(d.expiry)}</td>
      <td class="mono" style="font-size:11px;color:${isPerm?'var(--text-400)':days<0?'var(--danger)':days<30?'var(--danger)':days<60?'var(--warning)':'var(--success)'}">
        ${isPerm?'∞':days<0?'Kadaluarsa':days+'hr'}
      </td>
      <td>${statusBadge}</td>
      <td style="white-space:nowrap;">
        <button class="btn btn-ghost btn-xs" onclick="openCrewDocModal('${d.id}')"><i class="fa fa-edit"></i></button>
        <button class="btn btn-danger btn-xs" onclick="deleteCrewDoc('${d.id}')"><i class="fa fa-trash"></i></button>
      </td>
    </tr>`;
  }).join('');
}

