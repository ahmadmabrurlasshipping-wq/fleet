const crewName = id => { const c=DB.crew.find(x=>x.id===id); return c?c.name:'—'; };
const crewRank = id => { const c=DB.crew.find(x=>x.id===id); return c?c.rank.split('(')[0].trim():'—'; };
const AV_COLORS = ['#0099dd','#00cc88','#ff6b35','#cc44aa','#6644cc','#00aacc','#ee6644','#44bbaa'];
const getAvColor = name => { let h=0; for(let i=0;i<(name||'').length;i++) h=(h+(name||'').charCodeAt(i))%AV_COLORS.length; return AV_COLORS[h]; };
const getAv = name => (name||'?').trim().split(/\s+/).map(w=>w[0]).join('').substring(0,2).toUpperCase();
const statusInfo = {operational:{cls:'op',badge:'success',label:'Operasional'},route:{cls:'rt',badge:'info',label:'Berlayar'},drydock:{cls:'dk',badge:'warning',label:'Naik Dok'}};
const crewStatusInfo = {onboard:{badge:'success',label:'Di Kapal'},leave:{badge:'info',label:'Cuti'},standby:{badge:'orange',label:'Standby'},medical:{badge:'danger',label:'Cuti Medis'}};
const sevInfo = {low:{badge:'muted',label:'Rendah'},medium:{badge:'warning',label:'Sedang'},high:{badge:'danger',label:'Tinggi'},critical:{badge:'danger',label:'Kritis'}};

function expBadge(d) {
  if(!d) return '<span class="badge badge-muted">—</span>';
  const n = daysLeft(d);
  if(n<0) return `<span class="badge badge-danger">Kadaluarsa</span>`;
  if(n<30) return `<span class="badge badge-danger">${n} hari lagi</span>`;
  if(n<60) return `<span class="badge badge-warning">${n} hari lagi</span>`;
  return `<span class="badge badge-success">Valid ✓</span>`;
}
function addActivity(text, ship, col='var(--neon)') {
  DB.activities.unshift({time:'Baru saja',text,ship:ship||'—',col});
  if(DB.activities.length>12) DB.activities.pop();
}

