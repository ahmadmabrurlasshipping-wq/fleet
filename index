function renderDocuments() {
  populateDropdowns();
  const vf=document.getElementById('doc-v-filter')?.value||'';
  const tf=document.getElementById('doc-t-filter')?.value||'';
  let docs=DB.documents;
  if(vf) docs=docs.filter(d=>d.vessel===vf);
  if(tf) docs=docs.filter(d=>d.type===tf);
  const expired=docs.filter(d=>daysLeft(d.expiry)<0).length;
  const soon=docs.filter(d=>{const x=daysLeft(d.expiry);return x>=0&&x<60;}).length;
  const valid=docs.filter(d=>daysLeft(d.expiry)>=60).length;
  ['doc-total','doc-valid','doc-soon','doc-expired'].forEach((id,i)=>{const el=document.getElementById(id);if(el)el.textContent=[docs.length,valid,soon,expired][i];});
  // Urgent alerts
  const urgEl=document.getElementById('doc-urgent-alerts');
  if(urgEl){
