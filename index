function navTo(page) {
  CUR_PAGE = page;
  document.querySelectorAll('.ni').forEach(el=>el.classList.remove('active'));
  const el = document.querySelector(`.ni[data-page="${page}"]`);
  if(el) el.classList.add('active');
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  const pg = document.getElementById(`page-${page}`);
  if(pg) pg.classList.add('active');
  const info = PAGE_INFO[page]||{title:page,sub:''};
  document.getElementById('tb-title').textContent = info.title;
  document.getElementById('tb-sub').textContent = info.sub;
  document.getElementById('notif-panel').classList.remove('open');
  renderPage(page);
}
