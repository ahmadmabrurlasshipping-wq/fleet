<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LAS Fleet Monitoring System — PT. Pelayaran Lestari Abadi Serasi</title>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
:root {
  --navy-950:#020b18;--navy-900:#040f22;--navy-800:#071630;--navy-700:#0d2040;
  --glass-bg:rgba(7,22,48,0.72);--glass-bg2:rgba(13,32,64,0.55);
  --glass-border:rgba(0,180,255,0.16);--glass-border2:rgba(0,180,255,0.08);
  --neon:#00d4ff;--neon2:#00ffcc;--orange:#ff6b35;--orange2:#ffaa44;
  --text-100:#e8f4ff;--text-200:#b0cfe8;--text-400:#5a8aaa;--text-600:#2a4a6a;
  --success:#00e5a0;--danger:#ff3d5a;--warning:#ffb020;--info:#00d4ff;
  --sidebar-w:252px;--topbar-h:62px;--radius:14px;--radius-sm:9px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:14px}
body{font-family:'Outfit',sans-serif;background:var(--navy-950);color:var(--text-100);height:100vh;overflow:hidden;-webkit-font-smoothing:antialiased}
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:rgba(0,180,255,0.2);border-radius:2px}
.mono{font-family:'IBM Plex Mono',monospace}
#bg{position:fixed;inset:0;z-index:0;
  background:radial-gradient(ellipse 90% 70% at 10% 0%,rgba(0,80,160,0.18) 0%,transparent 55%),
             radial-gradient(ellipse 60% 50% at 85% 90%,rgba(255,107,53,0.07) 0%,transparent 50%),
             linear-gradient(180deg,var(--navy-950) 0%,#030d1e 100%)}
#bg::after{content:'';position:absolute;inset:0;
  background-image:linear-gradient(rgba(0,180,255,0.025) 1px,transparent 1px),
                   linear-gradient(90deg,rgba(0,180,255,0.025) 1px,transparent 1px);
  background-size:50px 50px}

/* ── LOGIN ── */
#login-page{position:fixed;inset:0;z-index:200;display:flex;align-items:center;justify-content:center;
  background:radial-gradient(ellipse 80% 60% at 20% 10%,rgba(0,100,200,0.15) 0%,transparent 60%),
             radial-gradient(ellipse 60% 50% at 80% 80%,rgba(255,107,53,0.08) 0%,transparent 50%),var(--navy-950)}
#login-page::before{content:'';position:absolute;inset:0;
  background-image:linear-gradient(rgba(0,180,255,0.03) 1px,transparent 1px),
                   linear-gradient(90deg,rgba(0,180,255,0.03) 1px,transparent 1px);background-size:50px 50px}
.login-box{position:relative;z-index:1;background:rgba(7,22,48,0.88);border:1px solid rgba(0,212,255,0.2);
  border-radius:20px;padding:40px 44px;width:420px;backdrop-filter:blur(24px);
  box-shadow:0 0 60px rgba(0,100,200,0.2)}
.login-box::before{content:'';position:absolute;top:0;left:20%;right:20%;height:1px;
  background:linear-gradient(90deg,transparent,var(--neon),transparent)}
.login-logo{text-align:center;margin-bottom:28px}
.login-logo-icon{width:64px;height:64px;border-radius:16px;background:linear-gradient(135deg,var(--neon),#0088cc);
  display:inline-flex;align-items:center;justify-content:center;font-size:28px;margin-bottom:12px;box-shadow:0 0 24px rgba(0,212,255,0.3)}
.login-logo h1{font-size:15px;font-weight:700;color:var(--text-100);letter-spacing:0.3px}
.login-logo p{font-size:10px;color:var(--text-400);letter-spacing:1.2px;text-transform:uppercase;margin-top:3px}
.form-field{margin-bottom:14px}
.form-field label{display:block;font-size:10px;font-weight:700;color:var(--text-400);letter-spacing:1px;text-transform:uppercase;margin-bottom:6px}
.field-wrap{position:relative}
.field-wrap .fi{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--text-400);font-size:13px}
.field-wrap input{width:100%;padding:10px 12px 10px 38px;background:rgba(0,0,0,0.35);border:1px solid var(--glass-border);
  border-radius:var(--radius-sm);color:var(--text-100);font-family:'Outfit',sans-serif;font-size:13px;outline:none;transition:all .2s}
.field-wrap input:focus{border-color:rgba(0,212,255,0.4);background:rgba(0,20,50,0.5)}
.field-wrap input::placeholder{color:var(--text-600)}
.login-roles{display:flex;gap:8px;margin-bottom:18px}
.role-chip{flex:1;padding:8px;text-align:center;border-radius:var(--radius-sm);
  background:rgba(0,0,0,0.3);border:1px solid var(--glass-border2);font-size:11px;color:var(--text-400);cursor:pointer;transition:all .2s}
.role-chip.active{background:rgba(0,212,255,0.12);border-color:rgba(0,212,255,0.3);color:var(--neon)}
.btn-login{width:100%;padding:12px;border:none;border-radius:var(--radius-sm);background:linear-gradient(135deg,#0099dd,#0066aa);
  color:#fff;font-family:'Outfit',sans-serif;font-size:14px;font-weight:600;cursor:pointer;transition:all .2s;
  display:flex;align-items:center;justify-content:center;gap:8px;box-shadow:0 0 20px rgba(0,150,220,0.3)}
.btn-login:hover{transform:translateY(-1px);box-shadow:0 0 30px rgba(0,180,255,0.4)}
.login-hint{text-align:center;font-size:11px;color:var(--text-600);margin-top:14px}

/* ── LAYOUT ── */
#app{position:relative;z-index:1;height:100vh;display:flex}
#sidebar{width:var(--sidebar-w);flex-shrink:0;background:rgba(4,15,34,0.92);border-right:1px solid var(--glass-border2);
  backdrop-filter:blur(20px);display:flex;flex-direction:column;overflow-y:auto;overflow-x:hidden}
.sb-head{padding:16px 14px 12px;border-bottom:1px solid var(--glass-border2);flex-shrink:0}
.brand{display:flex;align-items:center;gap:10px}
.brand-icon{width:36px;height:36px;border-radius:9px;flex-shrink:0;background:linear-gradient(135deg,var(--neon),#0077bb);
  display:flex;align-items:center;justify-content:center;font-size:16px;box-shadow:0 0 14px rgba(0,212,255,0.25)}
.brand-text .b1{font-size:13px;font-weight:800;letter-spacing:1px;color:var(--text-100);line-height:1}
.brand-text .b2{font-size:9px;color:var(--text-400);letter-spacing:1.5px;text-transform:uppercase;margin-top:2px}
.sb-nav{flex:1;padding:6px 10px}
.nav-sec-lbl{font-size:9px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--text-600);padding:9px 8px 5px}
.ni{display:flex;align-items:center;gap:9px;padding:8px 10px;border-radius:8px;cursor:pointer;
  font-size:12.5px;font-weight:500;color:var(--text-400);transition:all .18s;position:relative;margin-bottom:1px;white-space:nowrap}
.ni:hover{background:rgba(0,180,255,0.07);color:var(--text-200)}
.ni.active{background:rgba(0,212,255,0.12);color:var(--neon);border:1px solid rgba(0,212,255,0.18)}
.ni.active::before{content:'';position:absolute;left:0;top:20%;bottom:20%;width:3px;background:var(--neon);border-radius:0 2px 2px 0}
.ni .icon{width:18px;text-align:center;font-size:13px;flex-shrink:0}
.nbadge{margin-left:auto;background:var(--danger);color:#fff;font-size:9px;font-weight:700;
  padding:1px 5px;border-radius:6px;min-width:16px;text-align:center}
.sb-foot{flex-shrink:0;padding:10px;border-top:1px solid var(--glass-border2)}
.user-pill{display:flex;align-items:center;gap:8px;padding:8px 10px;border-radius:9px;
  background:rgba(0,0,0,0.3);border:1px solid var(--glass-border2);cursor:pointer;transition:all .2s}
.user-pill:hover{background:rgba(0,180,255,0.07)}
.uav{width:28px;height:28px;border-radius:7px;flex-shrink:0;background:linear-gradient(135deg,var(--orange),#cc4400);
  display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff}
.uinfo .u1{font-size:12px;font-weight:600;color:var(--text-100)}
.uinfo .u2{font-size:10px;color:var(--text-400)}
.logout-btn{margin-left:auto;background:none;border:none;color:var(--text-600);cursor:pointer;font-size:13px;padding:4px;transition:color .2s}
.logout-btn:hover{color:var(--danger)}

/* ── CONTENT ── */
#content-area{flex:1;display:flex;flex-direction:column;overflow:hidden}
#topbar{height:var(--topbar-h);flex-shrink:0;background:rgba(4,15,34,0.88);border-bottom:1px solid var(--glass-border2);
  backdrop-filter:blur(20px);display:flex;align-items:center;padding:0 20px;gap:12px}
.tb-info{flex:1}
.tb-info .t1{font-size:15px;font-weight:700}
.tb-info .t2{font-size:11px;color:var(--text-400);margin-top:1px}
.tb-search{display:flex;align-items:center;gap:7px;background:rgba(0,0,0,0.3);border:1px solid var(--glass-border2);border-radius:9px;padding:7px 11px}
.tb-search input{background:none;border:none;outline:none;color:var(--text-100);font-family:'Outfit',sans-serif;font-size:12px;width:190px}
.tb-search input::placeholder{color:var(--text-600)}
.tb-icon{width:32px;height:32px;border-radius:8px;background:rgba(0,0,0,0.3);border:1px solid var(--glass-border2);
  display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:13px;color:var(--text-400);transition:all .2s;position:relative}
.tb-icon:hover{background:rgba(0,180,255,0.1);color:var(--neon)}
.tb-icon .dot{position:absolute;top:5px;right:5px;width:7px;height:7px;background:var(--danger);border-radius:50%;border:2px solid var(--navy-900)}
.tb-profile{display:flex;align-items:center;gap:8px;background:rgba(0,0,0,0.3);border:1px solid var(--glass-border2);
  padding:4px 11px 4px 4px;border-radius:20px;cursor:pointer;transition:all .2s}
.tb-profile:hover{background:rgba(0,180,255,0.08)}
.tp-av{width:24px;height:24px;border-radius:6px;background:linear-gradient(135deg,var(--orange),#cc4400);
  display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;color:#fff}
#page-area{flex:1;overflow-y:auto;padding:18px 20px 22px}

/* ── COMPONENTS ── */
.card{background:var(--glass-bg);border:1px solid var(--glass-border);border-radius:var(--radius);backdrop-filter:blur(12px);padding:16px 18px}
.card-sm{padding:12px 14px}
.ct{font-size:12px;font-weight:600;color:var(--text-400);letter-spacing:.3px;margin-bottom:12px;display:flex;align-items:center;gap:7px}
.ct i{font-size:13px}
.ctop{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
.sc{background:var(--glass-bg);border:1px solid var(--glass-border);border-radius:var(--radius);padding:14px 16px;position:relative;overflow:hidden;transition:all .2s;cursor:default}
.sc::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--neon),transparent);opacity:.3}
.sc:hover{border-color:rgba(0,212,255,0.25);transform:translateY(-1px)}
.sc .lbl{font-size:10px;font-weight:600;letter-spacing:.8px;text-transform:uppercase;color:var(--text-400)}
.sc .val{font-size:26px;font-weight:800;margin:4px 0 2px;font-family:'IBM Plex Mono',monospace}
.sc .sub{font-size:10.5px;display:flex;align-items:center;gap:4px}
.sc .sub.up{color:var(--success)} .sc .sub.down{color:var(--danger)} .sc .sub.warn{color:var(--warning)}
.sc .ico{position:absolute;right:12px;top:50%;transform:translateY(-50%);font-size:28px;opacity:.1}
.sc .bar{position:absolute;bottom:0;left:0;right:0;height:2px}
/* Grid */
.g{display:grid;gap:12px}
.g2{grid-template-columns:repeat(2,1fr)} .g3{grid-template-columns:repeat(3,1fr)} .g4{grid-template-columns:repeat(4,1fr)}
.g31{grid-template-columns:3fr 1fr} .g21{grid-template-columns:2fr 1fr} .g112{grid-template-columns:1fr 1fr 2fr}
/* Spacers */
.mb8{margin-bottom:8px} .mb12{margin-bottom:12px} .mb14{margin-bottom:14px} .mb16{margin-bottom:16px} .mb20{margin-bottom:20px}
.mt8{margin-top:8px} .mt12{margin-top:12px} .mt16{margin-top:16px}
/* Badge */
.badge{display:inline-flex;align-items:center;gap:3px;padding:2px 8px;border-radius:20px;font-size:10px;font-weight:600}
.badge::before{content:'●';font-size:7px}
.badge-success{background:rgba(0,229,160,.1);color:var(--success);border:1px solid rgba(0,229,160,.2)}
.badge-success::before{color:var(--success)}
.badge-danger{background:rgba(255,61,90,.1);color:var(--danger);border:1px solid rgba(255,61,90,.2)}
.badge-danger::before{color:var(--danger)}
.badge-warning{background:rgba(255,176,32,.1);color:var(--warning);border:1px solid rgba(255,176,32,.2)}
.badge-warning::before{color:var(--warning)}
.badge-info{background:rgba(0,212,255,.1);color:var(--neon);border:1px solid rgba(0,212,255,.2)}
.badge-info::before{color:var(--neon)}
.badge-orange{background:rgba(255,107,53,.1);color:var(--orange);border:1px solid rgba(255,107,53,.2)}
.badge-orange::before{color:var(--orange)}
.badge-muted{background:rgba(90,138,170,.1);color:var(--text-400);border:1px solid rgba(90,138,170,.15)}
.badge-muted::before{color:var(--text-400)}
/* Table */
.tbl{width:100%;border-collapse:collapse;font-size:12px}
.tbl th{padding:8px 10px;text-align:left;font-size:9px;font-weight:700;letter-spacing:1px;text-transform:uppercase;
  color:var(--text-600);border-bottom:1px solid rgba(0,180,255,.08);white-space:nowrap}
.tbl td{padding:10px 10px;border-bottom:1px solid rgba(0,180,255,.04);vertical-align:middle}
.tbl tr:last-child td{border-bottom:none}
.tbl tr:hover td{background:rgba(0,180,255,.03)}
.tbl-wrap{overflow-x:auto}
/* Buttons */
.btn{display:inline-flex;align-items:center;gap:5px;padding:7px 13px;border-radius:var(--radius-sm);font-size:12px;font-weight:600;cursor:pointer;border:none;font-family:'Outfit',sans-serif;transition:all .18s}
.btn-primary{background:linear-gradient(135deg,#0099dd,#0066aa);color:#fff;box-shadow:0 0 12px rgba(0,150,220,.2)}
.btn-primary:hover{transform:translateY(-1px);box-shadow:0 0 20px rgba(0,180,255,.35)}
.btn-ghost{background:var(--glass-bg2);border:1px solid var(--glass-border);color:var(--text-200)}
.btn-ghost:hover{background:rgba(0,180,255,.1);color:var(--neon)}
.btn-danger{background:rgba(255,61,90,.12);border:1px solid rgba(255,61,90,.25);color:var(--danger)}
.btn-danger:hover{background:rgba(255,61,90,.2)}
.btn-success{background:rgba(0,229,160,.1);border:1px solid rgba(0,229,160,.22);color:var(--success)}
.btn-orange{background:rgba(255,107,53,.12);border:1px solid rgba(255,107,53,.25);color:var(--orange)}
.btn-sm{padding:5px 10px;font-size:11px;border-radius:7px}
.btn-xs{padding:3px 7px;font-size:10px;border-radius:6px}
/* Tabs */
.tabs{display:flex;gap:2px;padding:3px;background:rgba(0,0,0,.3);border-radius:10px;width:fit-content}
.tab{padding:5px 13px;border-radius:7px;font-size:11px;font-weight:500;color:var(--text-400);cursor:pointer;transition:all .18s;white-space:nowrap}
.tab.active{background:var(--glass-bg2);color:var(--neon);border:1px solid rgba(0,212,255,.18)}
/* Alert */
.alert{display:flex;align-items:flex-start;gap:9px;padding:10px 12px;border-radius:var(--radius-sm);margin-bottom:7px;font-size:12px}
.alert i{font-size:14px;flex-shrink:0;margin-top:1px}
.alert-danger{background:rgba(255,61,90,.08);border:1px solid rgba(255,61,90,.2);color:#ff6688}
.alert-warning{background:rgba(255,176,32,.08);border:1px solid rgba(255,176,32,.2);color:var(--warning)}
.alert-info{background:rgba(0,212,255,.07);border:1px solid rgba(0,212,255,.18);color:var(--neon)}
.alert-success{background:rgba(0,229,160,.07);border:1px solid rgba(0,229,160,.18);color:var(--success)}
/* Progress */
.prog{height:5px;background:rgba(0,180,255,.1);border-radius:3px;overflow:hidden}
.prog-fill{height:100%;border-radius:3px;transition:width .8s}
.pf-blue{background:linear-gradient(90deg,var(--neon),#0088ee)}
.pf-green{background:linear-gradient(90deg,var(--success),#00ff88)}
.pf-orange{background:linear-gradient(90deg,var(--orange),var(--orange2))}
.pf-red{background:linear-gradient(90deg,var(--danger),#ff8888)}
.pf-yellow{background:linear-gradient(90deg,var(--warning),#ffe066)}
/* Timeline */
.tl-wrap{padding-left:16px;position:relative}
.tl-wrap::before{content:'';position:absolute;left:4px;top:0;bottom:0;width:1px;background:linear-gradient(to bottom,var(--neon),transparent)}
.tl-item{position:relative;margin-bottom:12px}
.tl-dot{position:absolute;left:-15px;top:4px;width:6px;height:6px;border-radius:50%;background:var(--neon);box-shadow:0 0 6px var(--neon)}
.tl-time{font-size:9px;color:var(--text-600);font-family:'IBM Plex Mono',monospace;margin-bottom:1px}
.tl-text{font-size:11.5px;color:var(--text-200)}
.tl-ship{font-size:10px;color:var(--neon);margin-top:1px}
/* Modal */
.modal-overlay{position:fixed;inset:0;z-index:300;background:rgba(0,5,15,.75);backdrop-filter:blur(8px);display:none;align-items:center;justify-content:center;padding:20px}
.modal-overlay.show{display:flex}
.modal{background:rgba(6,18,40,.97);border:1px solid rgba(0,212,255,.18);border-radius:18px;padding:22px 24px;
  width:500px;max-width:95vw;max-height:88vh;overflow-y:auto;position:relative;box-shadow:0 0 60px rgba(0,80,160,.3)}
.modal-lg{width:680px}
.modal::before{content:'';position:absolute;top:0;left:15%;right:15%;height:1px;background:linear-gradient(90deg,transparent,var(--neon),transparent)}
.modal-title{font-size:15px;font-weight:700;margin-bottom:16px;display:flex;align-items:center;gap:8px}
.modal-title i{color:var(--neon)}
.modal-close{position:absolute;top:14px;right:14px;width:26px;height:26px;border-radius:7px;
  background:rgba(0,0,0,.3);border:1px solid var(--glass-border2);display:flex;align-items:center;justify-content:center;
  cursor:pointer;color:var(--text-400);font-size:12px;transition:all .2s}
.modal-close:hover{background:rgba(255,61,90,.2);color:var(--danger)}
.modal-actions{display:flex;gap:8px;justify-content:flex-end;margin-top:16px;padding-top:12px;border-top:1px solid var(--glass-border2)}
/* Form */
.fg{margin-bottom:11px}
.fl{display:block;font-size:10px;font-weight:700;color:var(--text-400);letter-spacing:.5px;text-transform:uppercase;margin-bottom:5px}
.fi,.fs,.fta{width:100%;padding:8px 11px;background:rgba(0,0,0,.35);border:1px solid var(--glass-border);
  border-radius:var(--radius-sm);color:var(--text-100);font-family:'Outfit',sans-serif;font-size:12.5px;outline:none;transition:all .18s}
.fi:focus,.fs:focus,.fta:focus{border-color:rgba(0,212,255,.4);background:rgba(0,20,50,.45)}
.fi::placeholder,.fta::placeholder{color:var(--text-600)}
.fs option{background:#071630}
.fta{resize:vertical;min-height:72px}
.frow{display:grid;grid-template-columns:1fr 1fr;gap:10px}
/* Kanban */
.kanban{display:flex;gap:10px;overflow-x:auto;padding-bottom:6px}
.kc{min-width:195px;flex-shrink:0}
.kc-head{font-size:10px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:var(--text-400);
  padding:5px 2px 9px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--glass-border2);margin-bottom:8px}
.kcard{background:var(--glass-bg);border:1px solid var(--glass-border2);border-radius:9px;padding:10px 11px;
  margin-bottom:6px;cursor:pointer;transition:all .18s}
.kcard:hover{border-color:rgba(0,212,255,.3);transform:translateY(-1px)}
.kcard .kn{font-size:12px;font-weight:600;margin-bottom:2px}
.kcard .kr{font-size:10px;color:var(--neon)}
.kcard .ks{font-size:10px;color:var(--text-400);margin-top:4px}
.kcard .kd{font-size:9px;color:var(--text-600);margin-top:3px;font-family:'IBM Plex Mono',monospace}
/* Vessel card */
.vc{background:var(--glass-bg);border:1px solid var(--glass-border);border-radius:var(--radius);padding:15px;
  transition:all .22s;cursor:pointer;position:relative;overflow:hidden}
.vc:hover{border-color:rgba(0,212,255,.3);transform:translateY(-2px);box-shadow:0 8px 28px rgba(0,40,100,.4)}
.vc.op::before,.vc.rt::before,.vc.dk::before{content:'';position:absolute;top:0;left:0;right:0;height:2px}
.vc.op::before{background:linear-gradient(90deg,var(--success),var(--neon2))}
.vc.rt::before{background:linear-gradient(90deg,var(--neon),#0088ff)}
.vc.dk::before{background:linear-gradient(90deg,var(--warning),var(--orange))}
.vc .vn{font-size:13px;font-weight:800;margin-bottom:2px}
.vc .vt{font-size:9.5px;color:var(--text-400);letter-spacing:.5px;margin-bottom:9px}
.vc .vstats{display:grid;grid-template-columns:repeat(3,1fr);gap:5px;margin-bottom:9px;font-size:10px;color:var(--text-400)}
.vc .vstats span{display:block;font-size:12.5px;font-weight:700;color:var(--text-100);font-family:'IBM Plex Mono',monospace}
.vc .vloc{font-size:10px;color:var(--text-400);display:flex;align-items:center;gap:4px;margin-top:6px}
/* Crew avatar */
.cav-row{display:flex;align-items:center;gap:9px}
.cav{width:32px;height:32px;border-radius:8px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff}
.cinfo .c1{font-size:12.5px;font-weight:600}
.cinfo .c2{font-size:10px;color:var(--neon)}
/* MLC Grid */
.mlcg{display:grid;grid-template-columns:repeat(7,1fr);gap:3px}
.mlcc{aspect-ratio:1;border-radius:3px;display:flex;align-items:center;justify-content:center;font-size:8px;font-weight:700;cursor:pointer;transition:all .15s}
.mlcc:hover{transform:scale(1.3);z-index:1}
.mlc-w{background:rgba(0,212,255,.28);color:var(--neon)}
.mlc-r{background:rgba(0,229,160,.18);color:var(--success)}
.mlc-v{background:rgba(255,61,90,.35);color:var(--danger)}
/* Upload zone */
.upzone{border:2px dashed var(--glass-border);border-radius:var(--radius-sm);padding:20px;text-align:center;cursor:pointer;transition:all .2s;background:rgba(0,0,0,.2)}
.upzone:hover{border-color:rgba(0,212,255,.4);background:rgba(0,30,60,.3)}
/* Toast */
.toast-wrap{position:fixed;bottom:18px;right:18px;z-index:500;display:flex;flex-direction:column;gap:7px}
.toast{background:rgba(6,18,40,.97);border:1px solid var(--glass-border);border-radius:9px;padding:11px 14px;
  min-width:240px;max-width:340px;display:flex;align-items:center;gap:9px;font-size:12px;
  box-shadow:0 8px 22px rgba(0,0,0,.4);backdrop-filter:blur(12px);
  animation:tIn .3s ease,tOut .3s ease 3.7s forwards}
.ts{border-left:3px solid var(--success)} .td{border-left:3px solid var(--danger)}
.tw{border-left:3px solid var(--warning)} .ti{border-left:3px solid var(--neon)}
@keyframes tIn{from{opacity:0;transform:translateX(20px)}to{opacity:1;transform:translateX(0)}}
@keyframes tOut{to{opacity:0;transform:translateX(20px)}}
/* Notif panel */
#notif-panel{position:fixed;top:var(--topbar-h);right:0;width:300px;background:rgba(4,15,34,.97);
  border-left:1px solid var(--glass-border);backdrop-filter:blur(20px);height:calc(100vh - var(--topbar-h));
  overflow-y:auto;z-index:150;transform:translateX(100%);transition:transform .3s ease;padding:14px}
#notif-panel.open{transform:translateX(0)}
/* Toggle switch */
.tsw{position:relative;display:inline-block;width:34px;height:19px}
.tsw input{opacity:0;width:0;height:0}
.tsw span{position:absolute;inset:0;background:rgba(0,0,0,.4);border-radius:20px;cursor:pointer;transition:.2s;border:1px solid var(--glass-border)}
.tsw span::before{content:'';position:absolute;width:13px;height:13px;background:var(--text-400);border-radius:50%;left:2px;top:2px;transition:.2s}
.tsw input:checked+span{background:rgba(0,212,255,.2);border-color:rgba(0,212,255,.4)}
.tsw input:checked+span::before{transform:translateX(15px);background:var(--neon);box-shadow:0 0 5px var(--neon)}
/* Sep */
.sep{height:1px;background:var(--glass-border2);margin:12px 0}
/* Page anim */
.page{display:none;animation:pgIn .25s ease}
.page.active{display:block}
@keyframes pgIn{from{opacity:0;transform:translateY(7px)}to{opacity:1;transform:translateY(0)}}
/* Map */
.map-box{background:rgba(0,5,20,.8);border:1px solid var(--glass-border);border-radius:var(--radius);overflow:hidden}
.map-box iframe{width:100%;border:none;display:block}
/* Colours */
.text-neon{color:var(--neon)} .text-orange{color:var(--orange)} .text-success{color:var(--success)}
.text-danger{color:var(--danger)} .text-warning{color:var(--warning)} .text-muted{color:var(--text-400)}
/* Responsive */
