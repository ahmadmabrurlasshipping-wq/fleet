function genAlerts() {
  const alerts = [];
  DB.documents.forEach(d=>{
    const days=daysLeft(d.expiry);
    if(days<0) alerts.push({type:'danger',icon:'times-circle',msg:`<b>${d.name}</b> (${vesselName(d.vessel)}) sudah kadaluarsa!`});
    else if(days<30) alerts.push({type:'danger',icon:'exclamation-triangle',msg:`<b>${d.name}</b> — ${vesselName(d.vessel)} kadaluarsa dalam <b>${days} hari</b>`});
    else if(days<60) alerts.push({type:'warning',icon:'exclamation-triangle',msg:`<b>${d.name}</b> — ${vesselName(d.vessel)} kadaluarsa dalam ${days} hari`});
  });
  DB.mlcLogs.forEach(l=>{
    if(l.rest<10) alerts.push({type:'danger',icon:'clock',msg:`<b>Pelanggaran MLC:</b> ${crewName(l.crew)} — hanya ${l.rest}j istirahat (min. 10j/24j)`});
  });
  DB.crew.forEach(c=>{
    const d=daysLeft(c.cocExp);
    if(d<0) alerts.push({type:'danger',icon:'certificate',msg:`<b>COC kadaluarsa:</b> ${c.name} (${c.rank.split('(')[0].trim()})`});
    else if(d<30) alerts.push({type:'warning',icon:'certificate',msg:`<b>COC segera habis:</b> ${c.name} — ${d} hari lagi`});
  });
  const gapVessels = DB.vessels.filter(v=>v.status!=='drydock' && DB.crew.filter(c=>c.vessel===v.id&&c.status==='onboard').length<13);
  gapVessels.forEach(v=>{ const onb=DB.crew.filter(c=>c.vessel===v.id&&c.status==='onboard').length; alerts.push({type:'warning',icon:'users',msg:`<b>Kru kurang:</b> ${v.name} hanya ${onb}/13 kru onboard`}); });
  return alerts;
}
function renderAlerts() {
  const el = document.getElementById('dash-alerts');
  if(!el) return;
  const alerts = genAlerts().slice(0,5);
  el.innerHTML = alerts.map(a=>`<div class="alert alert-${a.type}"><i class="fa fa-${a.icon}"></i><div>${a.msg}</div></div>`).join('')
    || '<div class="alert alert-success"><i class="fa fa-check-circle"></i><div>Tidak ada peringatan aktif saat ini</div></div>';
}
function renderTimeline() {
  const el = document.getElementById('dash-timeline');
  if(!el) return;
  el.innerHTML = DB.activities.map(a=>`<div class="tl-item"><div class="tl-dot" style="background:${a.col}"></div><div class="tl-time">${a.time}</div><div class="tl-text">${a.text}</div><div class="tl-ship">${a.ship}</div></div>`).join('');
}
