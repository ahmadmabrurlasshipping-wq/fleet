function saveCrewDoc() {
  const id = document.getElementById('cdoc-id').value;
  const gs = eid => document.getElementById(eid)?.value||'';
  const crewId = gs('cdoc-crew-sel');
  const type   = gs('cdoc-type-sel');
  if(!crewId){ toast('d','Pilih nama kru terlebih dahulu'); return; }
  if(!type){ toast('d','Pilih jenis sertifikat'); return; }
  // For permanent docs set expiry to far future
  let expiry = gs('cdoc-expiry');
  if(!expiry && ['Seaman Book','Passport','COC'].includes(type)) expiry='';
  const data = {
    crewId, type,
    docNumber: gs('cdoc-number'),
    issuer:    gs('cdoc-issuer'),
    place:     gs('cdoc-place'),
    issue:     gs('cdoc-issue'),
    expiry:    expiry||'9999-12-31',
    status:    gs('cdoc-status'),
    notes:     gs('cdoc-notes'),
  };
  if(!DB.crewDocs) DB.crewDocs=[];
  if(id){ const idx=DB.crewDocs.findIndex(x=>x.id===id); if(idx>-1) DB.crewDocs[idx]={...DB.crewDocs[idx],...data}; }
  else DB.crewDocs.push({id:genId('cd'),...data});
  saveDB(); updateGlobal();
  closeModal('m-crewdoc');
  if(CUR_PAGE==='crewdocs') renderCrewDocs();
  const c = DB.crew.find(x=>x.id===crewId)||{name:'?'};
  toast('s', `Sertifikat ${type} — ${c.name} ${id?'diperbarui':'ditambahkan'}`);
}

function deleteCrewDoc(id) {
  const d=(DB.crewDocs||[]).find(x=>x.id===id);
  const c=DB.crew.find(x=>x.id===d?.crewId)||{name:'?'};
  confirm$(`Hapus sertifikat ${d?.type||''} milik ${c.name}?`, ()=>{
    DB.crewDocs=(DB.crewDocs||[]).filter(x=>x.id!==id);
    saveDB(); updateGlobal(); renderCrewDocs();
    toast('s','Dokumen kru dihapus');
  });
}



function exportPayrollCSV() {
  const vesFilter = (document.getElementById('payroll-vessel-filter')||{}).value||'';
  const rows = (DB.payroll||[]).filter(p=>!vesFilter||p.vesselId===vesFilter);
  if(!rows.length){ toast('w','Tidak ada data untuk diekspor'); return; }
  const headers = ['No','Nama','Jabatan','Kapal','Gaji Pokok','Tunjangan Ops','Tambahan Lain','Total Gaji','BPJS TK','BPJS Kes','PPh21','Gaji Bersih','No Rekening','Bank','Keterangan'];
  const csvRows = [headers.join(',')];
  rows.forEach((p,i)=>{
    const c = DB.crew.find(x=>x.id===p.crewId)||{name:'—',rank:'—'};
    const v = DB.vessels.find(x=>x.id===p.vesselId)||{name:'—'};
    csvRows.push([i+1,`"${c.name}"`,`"${c.rank}"`,`"${v.name}"`,p.gajiPokok,p.tunjanganOps,p.tambahanLain||0,p.totalGaji,p.bpjsTK||0,p.bpjsKes||0,p.potonganPPh21||0,p.gajiBersih,`"${p.rekening||''}"`,`"${p.bank||''}"`,`"${p.keterangan||''}"`].join(','));
  });
  const blob = new Blob([csvRows.join('\n')], {type:'text/csv'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a'); a.href=url; a.download='payroll-kru-'+new Date().toISOString().slice(0,7)+'.csv'; a.click();
  toast('s','CSV berhasil diunduh');
}



