function updateKPIs() {
  const v = DB.vessels, c = DB.crew, d = DB.documents, m = DB.mlcLogs;
  const vesOp = v.filter(x=>x.status!=='drydock').length;
  const docsExp = d.filter(x=>daysLeft(x.expiry)<60).length;
  const mlcV = m.filter(x=>x.rest<10||x.hours>14).length;
  const kc=document.getElementById('kpi-crew'),kv=document.getElementById('kpi-vessels'),
        kd=document.getElementById('kpi-docs'),km=document.getElementById('kpi-mlc');
  if(kc) kc.textContent=c.length;
  if(kv) kv.textContent=`${vesOp}/${v.length}`;
  if(kd) kd.textContent=docsExp;
  if(km) km.textContent=mlcV;
  const ksub=document.getElementById('kpi-vessels-sub');
  if(ksub){ ksub.className='sub '+(v.filter(x=>x.status==='drydock').length>0?'warn':'up'); ksub.innerHTML=`<i class="fa fa-ship"></i><span>${v.filter(x=>x.status==='drydock').length} naik dok, ${v.filter(x=>x.status==='route').length} berlayar</span>`; }
}
function renderFleetCards() {
  const el = document.getElementById('dash-fleet-cards');
  if(!el) return;
  el.innerHTML = DB.vessels.map(v=>{
    const si = statusInfo[v.status]||statusInfo.operational;
    const pct = v.status==='drydock' ? Math.round((v.crew/13)*100) : 100;
    return `<div class="vc ${si.cls}" onclick="navTo('fleet')">
