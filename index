function renderPayrollTable() {
  const vesFilter = (document.getElementById('payroll-vessel-filter')||{}).value||'';
  const search = ((document.getElementById('payroll-search')||{}).value||'').toLowerCase();
  if(!DB.payroll) DB.payroll=[];
  let rows = DB.payroll.filter(p=>{
    if(vesFilter && p.vesselId!==vesFilter) return false;
    const c = DB.crew.find(x=>x.id===p.crewId)||{};
    if(search && !(c.name||'').toLowerCase().includes(search)) return false;
    return true;
  });
  // KPI
  const totalGaji = rows.reduce((s,p)=>s+p.gajiPokok,0);
  const totalTunjangan = rows.reduce((s,p)=>s+p.tunjanganOps+(p.tambahanLain||0),0);
  const totalAll = rows.reduce((s,p)=>s+p.totalGaji,0);
  const el = id => document.getElementById(id);
  if(el('pay-kpi-crew')) el('pay-kpi-crew').textContent = rows.length;
  if(el('pay-kpi-base')) el('pay-kpi-base').textContent = FMT_IDR(totalGaji);
  if(el('pay-kpi-allowance')) el('pay-kpi-allowance').textContent = FMT_IDR(totalTunjangan);
  if(el('pay-kpi-total')) el('pay-kpi-total').textContent = FMT_IDR(totalAll);
  // Table
  const tbody = document.getElementById('payroll-tbody');
  if(!tbody) return;
  if(rows.length===0){ tbody.innerHTML=`<tr><td colspan="14" style="text-align:center;color:var(--text-400);padding:24px;">Tidak ada data payroll</td></tr>`; return; }
  tbody.innerHTML = rows.map((p,i)=>{
    const c = DB.crew.find(x=>x.id===p.crewId)||{name:'—',rank:'—'};
    const v = DB.vessels.find(x=>x.id===p.vesselId)||{name:'—'};
    const bpjsTotal = (p.bpjsTK||0)+(p.bpjsKes||0)+(p.jkk||0)+(p.jkm||0)+(p.jpKaryawan||0);
    return `<tr>
      <td style="color:var(--text-600)">${i+1}</td>
      <td><div style="font-weight:600;font-size:12px;">${c.name}</div></td>
      <td><span class="badge badge-info" style="font-size:9px;">${c.rank}</span></td>
      <td style="font-size:11px;color:var(--neon)">${v.name}</td>
      <td class="mono" style="font-size:11px;">${FMT_IDR(p.gajiPokok)}</td>
      <td class="mono" style="font-size:11px;color:var(--orange)">${FMT_IDR(p.tunjanganOps)}</td>
      <td class="mono" style="font-size:10px;color:var(--text-400)">${p.tambahanLain?FMT_IDR(p.tambahanLain):'—'}</td>
      <td class="mono" style="font-size:11px;font-weight:600;">${FMT_IDR(p.totalGaji)}</td>
      <td class="mono" style="font-size:11px;color:var(--danger)">(${FMT_IDR(bpjsTotal)})</td>
      <td class="mono" style="font-size:11px;color:var(--danger)">(${FMT_IDR(p.potonganPPh21||0)})</td>
      <td class="mono" style="font-size:11px;color:var(--success);font-weight:700;">${FMT_IDR(p.gajiBersih)}</td>
      <td style="font-size:10px;color:var(--text-400);">${p.rekening||''}<br><span style="color:var(--neon)">${p.bank||''}</span></td>
      <td style="font-size:10px;color:var(--text-400);">${p.keterangan||'—'}</td>
      <td style="white-space:nowrap;">
        <button class="btn btn-ghost btn-xs" onclick="openPayrollModal('${p.id}')" title="Edit"><i class="fa fa-edit"></i></button>
        <button class="btn btn-danger btn-xs" onclick="deletePayroll('${p.id}')" title="Hapus"><i class="fa fa-trash"></i></button>
      </td>
    </tr>`;
  }).join('');
}

function renderPayrollSummary() {
  const el = document.getElementById('payroll-by-vessel');
  if(!el) return;
  el.innerHTML = DB.vessels.map(v=>{
    const crew = DB.payroll ? DB.payroll.filter(p=>p.vesselId===v.id) : [];
    const total = crew.reduce((s,p)=>s+p.totalGaji,0);
    return `<div class="sc" style="cursor:pointer" onclick="document.getElementById('payroll-vessel-filter').value='${v.id}';renderPayrollTable()">
      <div class="lbl">${v.name}</div>
      <div class="val" style="font-size:14px;color:var(--success)">${FMT_IDR(total)}</div>
