function calcPayrollModal() {
  const gv = id => parseFloat(document.getElementById(id)?.value)||0;
  const aktual = gv('pay-gaji-aktual');
  const tambahan = gv('pay-tambahan-kenaikan');
  const ops = gv('pay-ops');
  const tambahanLain = gv('pay-tambahan-lain');
  const hari = gv('pay-hari-aktif');
  const penguranganOff = hari < 30 ? Math.round(aktual / 30 * (30 - hari)) : 0;
  document.getElementById('pay-pengurangan').value = penguranganOff;
  const totalGaji = aktual + tambahan + ops + tambahanLain - penguranganOff;
  document.getElementById('pay-total-gaji').value = totalGaji;
  const bpjsKes  = gv('pay-bpjs-kes');
  const bpjsTK   = gv('pay-bpjs-tk');
  const jpKary   = gv('pay-jp-karyawan');
  const pph21    = gv('pay-pph21');
  const mcu      = gv('pay-mcu');
  const bersih = totalGaji - bpjsKes - bpjsTK - jpKary - pph21 - mcu;
  document.getElementById('pay-gaji-bersih').value = Math.round(bersih);
  toast('i', `Total Gaji: ${FMT_IDR(totalGaji)} → Bersih: ${FMT_IDR(bersih)}`);
}

