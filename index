  // Doc vessel
  ['d-vessel','inc-vessel','voy-vessel','mlc-vessel-sel'].forEach(id=>{ const el=document.getElementById(id); if(el) el.innerHTML=vesselOpts; });
  // Rotation crew + vessel
  const rcEl = document.getElementById('rot-crew');
  if(rcEl) rcEl.innerHTML = crewOpts;
