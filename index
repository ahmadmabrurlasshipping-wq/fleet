  const vRes=DB.vessels.filter(x=>x.name.toLowerCase().includes(v));
  const cRes=DB.crew.filter(x=>x.name.toLowerCase().includes(v));
  const dRes=DB.documents.filter(x=>x.name.toLowerCase().includes(v));
