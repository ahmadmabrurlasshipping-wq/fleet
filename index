// ENVIRONMENT DETECTION & STORAGE LAYER
// Otomatis mendeteksi apakah berjalan di Google Apps Script
// atau di browser lokal (localhost / file://)
// ═══════════════════════════════════════════════════════════════
const IS_GAS = (typeof google !== 'undefined' &&
                typeof google.script !== 'undefined' &&
                typeof google.script.run !== 'undefined');

// Wrap google.script.run dalam Promise agar bisa dipakai async/await
function gasRun(fnName, ...args) {
  return new Promise((resolve, reject) => {
    if (!IS_GAS) { reject(new Error('Not in GAS environment')); return; }
    try {
      google.script.run
        .withSuccessHandler(data => resolve(data))
        .withFailureHandler(err  => reject(err))
        [fnName](...args);
    } catch(e) { reject(e); }
  });
}

// ── Persistent Storage ─────────────────────────────────────────
// GAS: data tersimpan di Google Sheet via PropertiesService
// Lokal: data tersimpan di localStorage

function loadDB() {
  try {
    const r = localStorage.getItem('las_db');
    return r ? JSON.parse(r) : null;
  } catch(e) { return null; }
}

function saveDB() {
  // 1. Selalu simpan ke localStorage (caching lokal)
  try { localStorage.setItem('las_db', JSON.stringify(DB)); } catch(e) {}
  // 2. Kalau di GAS, kirim ke server (non-blocking)
  if (IS_GAS) {
    gasRun('serverSaveDB', JSON.stringify(DB))
      .catch(err => console.warn('GAS saveDB failed:', err));
  }
}

async function syncFromGAS() {
  if (!IS_GAS) return;
  try {
    toast('i', '🔄 Memuat data dari Google Sheets...');
    const jsonStr = await gasRun('serverLoadDB');
    if (jsonStr) {
      const remote = JSON.parse(jsonStr);
      // Merge: remote wins for existing data, local wins for new unsaved
      Object.assign(DB, remote);
      localStorage.setItem('las_db', JSON.stringify(DB));
      renderPage(CUR_PAGE);
      updateGlobal();
      toast('s', '✅ Data berhasil disinkronkan dari Google Sheets');
    }
  } catch(e) {
    console.warn('syncFromGAS error:', e);
    toast('w', '⚠️ Sinkronisasi GAS gagal — menggunakan data lokal');
  }
}

