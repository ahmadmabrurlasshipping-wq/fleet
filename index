function renderMlcTable() {
  const vFilter=document.getElementById('mlc-filter-vessel')?.value||'';
  let logs=DB.mlcLogs;
  if(vFilter) logs=logs.filter(l=>l.vessel===vFilter);
  const tbody=document.getElementById('mlc-tbody');
  if(!tbody) return;
  tbody.innerHTML=logs.map(l=>{
    const c=DB.crew.find(x=>x.id===l.crew);
    const viol=l.rest<10||l.hours>14;
    const warn=!viol&&(l.rest<11||l.hours>13);
    return `<tr>
      <td><div class="cav-row"><div class="cav" style="background:${c?getAvColor(c.name):'#555'};width:28px;height:28px;font-size:10px;">${c?getAv(c.name):'?'}</div><div class="cinfo"><div class="c1" style="font-size:12px;">${c?c.name:'—'}</div></div></div></td>
      <td style="font-size:10px;color:var(--text-400);">${c?c.rank.split('(')[0].trim():'—'}</td>
      <td style="font-size:11px;color:var(--neon)">${l.vessel?vesselName(l.vessel):c&&c.vessel?vesselName(c.vessel):'—'}</td>
      <td class="mono" style="font-size:10px;">${fmtDate(l.date)}</td>
      <td><span class="mono" style="color:${l.hours>14?'var(--danger)':l.hours>13?'var(--warning)':'var(--success)'}">${l.hours}j</span></td>
      <td><span class="mono" style="color:${l.rest<10?'var(--danger)':l.rest<11?'var(--warning)':'var(--success)'}">${l.rest}j</span></td>
      <td><span class="badge badge-${viol?'danger':warn?'warning':'success'}">${viol?'⛔ Pelanggaran':warn?'⚠ Berisiko':'✓ Patuh'}</span></td>
      <td><button class="btn btn-danger btn-xs" onclick="deleteMlc('${l.id}')"><i class="fa fa-trash"></i></button></td>
    </tr>`;
  }).join('')||`<tr><td colspan="8" style="text-align:center;padding:16px;color:var(--text-400);">Belum ada data jam kerja</td></tr>`;
}
function buildMlcGrid() {
  const el=document.getElementById('mlc-grid');
  if(!el) return;
  const data=DB.mlcLogs.slice(-7).map(l=>({ hours:l.hours, rest:l.rest, viol:l.rest<10||l.hours>14 }));
  while(data.length<7) data.push({hours:0,rest:24,viol:false});
  // 4 rows × 7 cols: show work blocks per day
  const rows=[]; for(let r=0;r<4;r++){ for(let d=0;d<7;d++){ const l=data[d]; let cls='mlc-r'; if(l.viol&&r<2) cls='mlc-v'; else if(l.hours>0&&r<Math.round(l.hours/6)) cls='mlc-w'; rows.push(cls); } }
  el.innerHTML=rows.map((c,i)=>`<div class="mlcc ${c}" title="${c==='mlc-w'?'Kerja':c==='mlc-v'?'Pelanggaran':'Istirahat'}">${c==='mlc-w'?'W':c==='mlc-v'?'!':'Z'}</div>`).join('');
  const leg=document.getElementById('mlc-grid-legend');
  if(leg){
    const viols=data.filter(l=>l.viol).length;
    leg.textContent=viols>0?`⚠ ${viols} hari dengan pelanggaran MLC terdeteksi`:'✓ Tidak ada pelanggaran dalam 7 hari terakhir';
    leg.style.color=viols>0?'var(--danger)':'var(--success)';
  }
}
